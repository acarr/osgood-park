---
import Layout from "@/layouts/Layout.astro";
import { Hero157 } from "@/components/hero157";
import { Footer60 } from "@/components/footer60";
import TideWaterSection from "@/components/sections/TideWaterSection";
import DocumentsSection from "@/components/sections/DocumentsSection.astro";
---

<Layout>
  <main>
    <Hero157 />

    <section id="tides" class="border-t border-border py-24 md:py-32">
      <div class="container mx-auto px-6">
        <div class="mb-12 max-w-2xl">
          <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">
            Tides &amp; Water Safety
          </h2>
          <p class="mt-4 text-muted-foreground md:text-lg">
            Today's tide schedule for Salem Harbor and the latest water-safety
            test for Osgood beach.
          </p>
        </div>
        <TideWaterSection client:load />
      </div>
    </section>

    <DocumentsSection />

    <Footer60
      logo={{
        url: "#",
        src: "",
        alt: "",
        title: "Osgood-Park Neighborhood Association",
      }}
      sections={[
        {
          title: "Menu",
          links: [
            { name: "Tides & Water", href: "#tides" },
            { name: "Forms", href: "#forms" },
          ],
        },
      ]}
      socialLinks={[]}
    />
  </main>
</Layout>
